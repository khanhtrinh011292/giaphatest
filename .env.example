# ============================================================
# Quản Lý Gia Phả Việt Nam — Cấu hình môi trường
# ============================================================
# Hướng dẫn:
#   1. Chép file này thành ".env" (dùng cho Docker / Synology NAS)
#      hoặc ".env.local" (dùng cho chạy local với npm/bun dev)
#   2. Điền đầy đủ các giá trị bên dưới
# ============================================================

# Tên ứng dụng hiển thị trên giao diện
SITE_NAME="Quản Lý Gia Phả Việt Nam"

# ---- Cấu hình Supabase ----
# Lấy từ: Supabase Dashboard > Project Settings > API
NEXT_PUBLIC_SUPABASE_URL="https://your-project.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY="your-anon-or-public-key"

# ---- Cấu hình cổng (chỉ dùng cho Docker / Synology) ----
# Cổng trên NAS để truy cập ứng dụng (mặc định: 3000)
# Thay đổi nếu cổng 3000 đã bị chiếm dụng bởi ứng dụng khác
APP_PORT=3000
